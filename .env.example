# Example environment variables for street

PORT=3000
HOST=0.0.0.0
NODE_ENV=development

PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=street
PG_USER=street
PG_PASSWORD=street_secret

JWT_SECRET=change-this-to-a-random-32-char-minimum-secret
# Generate with: openssl rand -hex 32
SESSION_KEY=REPLACE_WITH_GENERATED_KEY_run_openssl_rand_-hex_32

# CORS — comma-separated list of allowed origins (required in production)
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# Leave unset in development to allow all origins
ALLOWED_ORIGINS=

# Optional: Vault Mode
# KEK=your-kek-here
