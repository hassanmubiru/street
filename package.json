{
  "name": "@streetjs/core",
  "version": "1.0.1",
  "description": "Production-grade, memory-safe TypeScript backend framework built on Node.js core modules",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./http": {
      "import": "./dist/src/http/server.js",
      "types": "./dist/src/http/server.d.ts"
    },
    "./router": {
      "import": "./dist/src/router/router.js",
      "types": "./dist/src/router/router.d.ts"
    },
    "./database": {
      "import": "./dist/src/database/wire.js",
      "types": "./dist/src/database/wire.d.ts"
    },
    "./pool": {
      "import": "./dist/src/database/pool.js",
      "types": "./dist/src/database/pool.d.ts"
    },
    "./repository": {
      "import": "./dist/src/database/repository.js",
      "types": "./dist/src/database/repository.d.ts"
    },
    "./migrations": {
      "import": "./dist/src/database/migrations.js",
      "types": "./dist/src/database/migrations.d.ts"
    },
    "./security": {
      "import": "./dist/src/security/jwt.js",
      "types": "./dist/src/security/jwt.d.ts"
    },
    "./session": {
      "import": "./dist/src/security/session.js",
      "types": "./dist/src/security/session.d.ts"
    },
    "./vault": {
      "import": "./dist/src/security/vault.js",
      "types": "./dist/src/security/vault.d.ts"
    },
    "./ratelimit": {
      "import": "./dist/src/security/ratelimit.js",
      "types": "./dist/src/security/ratelimit.d.ts"
    },
    "./xss": {
      "import": "./dist/src/security/xss.js",
      "types": "./dist/src/security/xss.d.ts"
    },
    "./websocket": {
      "import": "./dist/src/websocket/server.js",
      "types": "./dist/src/websocket/server.d.ts"
    },
    "./sse": {
      "import": "./dist/src/websocket/sse.js",
      "types": "./dist/src/websocket/sse.d.ts"
    },
    "./cache": {
      "import": "./dist/src/cache/lru.js",
      "types": "./dist/src/cache/lru.d.ts"
    },
    "./telemetry": {
      "import": "./dist/src/telemetry/tracker.js",
      "types": "./dist/src/telemetry/tracker.d.ts"
    },
    "./cluster": {
      "import": "./dist/src/cluster/coordinator.js",
      "types": "./dist/src/cluster/coordinator.d.ts"
    },
    "./cli": {
      "import": "./dist/src/cli/kernel.js",
      "types": "./dist/src/cli/kernel.d.ts"
    },
    "./multipart": {
      "import": "./dist/src/multipart/parser.js",
      "types": "./dist/src/multipart/parser.d.ts"
    },
    "./webhook": {
      "import": "./dist/src/webhook/dispatcher.js",
      "types": "./dist/src/webhook/dispatcher.d.ts"
    },
    "./exceptions": {
      "import": "./dist/src/http/exceptions.js",
      "types": "./dist/src/http/exceptions.d.ts"
    }
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "dist/src/**/*.d.ts.map",
    "migrations/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "build:app": "tsc",
    "start": "node dist/src/main.js",
    "test": "node --test dist/tests/integration.test.js",
    "test:run": "tsc && node --test dist/tests/integration.test.js",
    "test:system": "tsc && node dist/tests/system/runner.js",
    "test:security": "tsc && node --test dist/tests/system/security.test.js",
    "test:memory": "tsc && node --test dist/tests/system/memory-safety.test.js",
    "test:load": "tsc && node --test dist/tests/system/load-testing.test.js",
    "test:fuzz": "tsc && node --test dist/tests/system/fuzz-testing.test.js",
    "test:chaos": "tsc && node --test dist/tests/system/chaos-testing.test.js",
    "test:infra": "tsc && node --test dist/tests/system/infrastructure.test.js",
    "test:system:ci": "tsc && node dist/tests/system/runner.js --ci --json --skip-pg",
    "migrate": "node dist/src/main.js migrate",
    "dev": "tsc && node dist/src/main.js",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build && npm run lint",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "keywords": [
    "typescript",
    "framework",
    "backend",
    "http",
    "server",
    "postgresql",
    "wire-protocol",
    "dependency-injection",
    "ioc",
    "websocket",
    "sse",
    "streaming",
    "memory-safe",
    "clustering",
    "jwt",
    "aes-gcm",
    "rate-limiting",
    "esm",
    "nodejs"
  ],
  "author": "street contributors",
  "license": "MIT",
  "homepage": "https://hassanmubiru.github.io/street",
  "repository": {
    "type": "git",
    "url": "https://github.com/hassanmubiru/street.git"
  },
  "bugs": {
    "url": "https://github.com/hassanmubiru/street/issues"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
