{
  "name": "street-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/cli",
    "build:core": "npm run build -w packages/core",
    "build:cli": "npm run build -w packages/cli",
    "start": "npm run start -w packages/core",
    "dev": "npm run dev -w packages/core",
    "test": "npm run test -w packages/core",
    "test:run": "npm run test:run -w packages/core",
    "test:cli": "npm run test -w packages/cli",
    "coverage:core": "npm run coverage -w packages/core",
    "coverage:cli": "npm run coverage -w packages/cli",
    "lint": "npm run lint -w packages/core",
    "clean": "npm run clean -w packages/core && npm run clean -w packages/cli",
    "lint:workflows": "bash scripts/validate-workflows.sh",
    "lint:security": "if command -v zizmor >/dev/null 2>&1; then zizmor --min-severity medium .; else echo 'zizmor not installed. Install with: cargo install zizmor'; fi",
    "prepare": "if test -d .git; then git config core.hooksPath .githooks; fi",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "release:dry-run": "bash scripts/release.sh patch --dry-run",
    "validate:publish": "bash scripts/validate-publish.sh",
    "verify:publish": "bash scripts/post-publish-verify.sh",
    "verify:codemods": "node scripts/verification/run.mjs upgrade.codemods --docs -- node --test packages/core/dist/tests/codemods.test.js packages/core/dist/tests/codemods-idempotence-pbt.test.js packages/core/dist/tests/codemods-safety-pbt.test.js packages/core/dist/tests/codemods-migration-examples.test.js packages/core/dist/tests/upgrade-breaking-pbt.test.js packages/core/dist/tests/upgrade-resolve-pbt.test.js",
    "test:release-renderer": "node --test scripts/tests/release-render-report.test.mjs",
    "verify:release": "node scripts/verification/run.mjs release.scorecard --docs -- node scripts/release/render-report.mjs"
  },
  "keywords": [
    "typescript",
    "framework",
    "backend",
    "http",
    "server",
    "postgresql",
    "monorepo",
    "street-framework",
    "streetjs"
  
  ],
  "author": "street contributors",
  "license": "MIT",
  "homepage": "https://hassanmubiru.github.io/street",
  "repository": {
    "type": "git",
    "url": "https://github.com/hassanmubiru/street.git"
  },
  "bugs": {
    "url": "https://github.com/hassanmubiru/street/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
