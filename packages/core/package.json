  "c8": {
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/tests/**"
    ],
    "reporter": [
      "text",
      "lcov",
      "html"
    ],
    "all": false,
    "check-coverage": true,
    "lines": 60,
    "functions": 60,
    "branches": 60,
    "statements": 60
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "postbuild": "node -e \"const fs=require('fs');const p=require('path');const s='src/database/sqlite';const d='dist/database/sqlite';fs.mkdirSync(d,{recursive:true});for(const f of ['sqlite3.wasm','sqlite3-node.mjs'])fs.copyFileSync(p.join(s,f),p.join(d,f));\"",
    "build:app": "tsc && node -e \"const fs=require('fs');const p=require('path');const s='src/database/sqlite';const d='dist/src/database/sqlite';fs.mkdirSync(d,{recursive:true});for(const f of ['sqlite3.wasm','sqlite3-node.mjs'])fs.copyFileSync(p.join(s,f),p.join(d,f));\"",
    "start": "node dist/main.js",
    "test": "node --test dist/tests/integration.test.js",
    "coverage": "c8 node --test --test-force-exit dist/tests/integration.test.js dist/tests/memory-leak.test.js dist/tests/wire-protocol.test.js dist/src/tests/diagnostics.test.js dist/src/tests/schema-inspector.test.js dist/src/tests/security-headers.test.js",
    "test:migration": "npm run build && npm run build:app && node --test --test-force-exit dist/tests/package-migration.test.js",
    "test:run": "tsc && node --test dist/tests/integration.test.js",
    "test:system": "tsc && node dist/tests/system/runner.js",
    "test:security": "tsc && node --test dist/tests/system/security.test.js",
    "test:memory": "tsc && node --test dist/tests/system/memory-safety.test.js",
    "test:load": "tsc && node --test dist/tests/system/load-testing.test.js",
    "test:fuzz": "tsc && node --test dist/tests/system/fuzz-testing.test.js",
    "test:chaos": "tsc && node --test dist/tests/system/chaos-testing.test.js",
    "test:infra": "tsc && node --test dist/tests/system/infrastructure.test.js",
    "test:system:ci": "tsc && node dist/tests/system/runner.js --ci --json --skip-pg",
    "migrate": "node dist/main.js migrate",
    "dev": "tsc && node dist/main.js",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "verify:pack": "node ../../scripts/verify-package.mjs",
    "prepublishOnly": "npm run clean && npm run build && npm run lint && npm run verify:pack",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
