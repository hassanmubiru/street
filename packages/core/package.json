{
  "name": "@streetjs/core",
  "version": "1.0.5",
  "description": "Production-grade, memory-safe TypeScript backend framework built on Node.js core modules",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./http": {
      "import": "./dist/http/server.js",
      "types": "./dist/http/server.d.ts"
    },
    "./router": {
      "import": "./dist/router/router.js",
      "types": "./dist/router/router.d.ts"
    },
    "./database": {
      "import": "./dist/database/wire.js",
      "types": "./dist/database/wire.d.ts"
    },
    "./pool": {
      "import": "./dist/database/pool.js",
      "types": "./dist/database/pool.d.ts"
    },
    "./repository": {
      "import": "./dist/database/repository.js",
      "types": "./dist/database/repository.d.ts"
    },
    "./migrations": {
      "import": "./dist/database/migrations.js",
      "types": "./dist/database/migrations.d.ts"
    },
    "./security": {
      "import": "./dist/security/jwt.js",
      "types": "./dist/security/jwt.d.ts"
    },
    "./session": {
      "import": "./dist/security/session.js",
      "types": "./dist/security/session.d.ts"
    },
    "./vault": {
      "import": "./dist/security/vault.js",
      "types": "./dist/security/vault.d.ts"
    },
    "./ratelimit": {
      "import": "./dist/security/ratelimit.js",
      "types": "./dist/security/ratelimit.d.ts"
    },
    "./xss": {
      "import": "./dist/security/xss.js",
      "types": "./dist/security/xss.d.ts"
    },
    "./websocket": {
      "import": "./dist/websocket/server.js",
      "types": "./dist/websocket/server.d.ts"
    },
    "./sse": {
      "import": "./dist/websocket/sse.js",
      "types": "./dist/websocket/sse.d.ts"
    },
    "./cache": {
      "import": "./dist/cache/lru.js",
      "types": "./dist/cache/lru.d.ts"
    },
    "./telemetry": {
      "import": "./dist/telemetry/tracker.js",
      "types": "./dist/telemetry/tracker.d.ts"
    },
    "./cluster": {
      "import": "./dist/cluster/coordinator.js",
      "types": "./dist/cluster/coordinator.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/kernel.js",
      "types": "./dist/cli/kernel.d.ts"
    },
    "./multipart": {
      "import": "./dist/multipart/parser.js",
      "types": "./dist/multipart/parser.d.ts"
    },
    "./webhook": {
      "import": "./dist/webhook/dispatcher.js",
      "types": "./dist/webhook/dispatcher.d.ts"
    },
    "./exceptions": {
      "import": "./dist/http/exceptions.js",
      "types": "./dist/http/exceptions.d.ts"
    }
  },
  "files": [
    "dist/cache/**/*.js",
    "dist/cache/**/*.js.map",
    "dist/cache/**/*.d.ts",
    "dist/cache/**/*.d.ts.map",
    "dist/cli/**/*.js",
    "dist/cli/**/*.js.map",
    "dist/cli/**/*.d.ts",
    "dist/cli/**/*.d.ts.map",
    "dist/cluster/**/*.js",
    "dist/cluster/**/*.js.map",
    "dist/cluster/**/*.d.ts",
    "dist/cluster/**/*.d.ts.map",
    "dist/core/**/*.js",
    "dist/core/**/*.js.map",
    "dist/core/**/*.d.ts",
    "dist/core/**/*.d.ts.map",
    "dist/database/**/*.js",
    "dist/database/**/*.js.map",
    "dist/database/**/*.d.ts",
    "dist/database/**/*.d.ts.map",
    "dist/http/**/*.js",
    "dist/http/**/*.js.map",
    "dist/http/**/*.d.ts",
    "dist/http/**/*.d.ts.map",
    "dist/multipart/**/*.js",
    "dist/multipart/**/*.js.map",
    "dist/multipart/**/*.d.ts",
    "dist/multipart/**/*.d.ts.map",
    "dist/router/**/*.js",
    "dist/router/**/*.js.map",
    "dist/router/**/*.d.ts",
    "dist/router/**/*.d.ts.map",
    "dist/security/**/*.js",
    "dist/security/**/*.js.map",
    "dist/security/**/*.d.ts",
    "dist/security/**/*.d.ts.map",
    "dist/telemetry/**/*.js",
    "dist/telemetry/**/*.js.map",
    "dist/telemetry/**/*.d.ts",
    "dist/telemetry/**/*.d.ts.map",
    "dist/webhook/**/*.js",
    "dist/webhook/**/*.js.map",
    "dist/webhook/**/*.d.ts",
    "dist/webhook/**/*.d.ts.map",
    "dist/websocket/**/*.js",
    "dist/websocket/**/*.js.map",
    "dist/websocket/**/*.d.ts",
    "dist/websocket/**/*.d.ts.map",
    "dist/index.js",
    "dist/index.js.map",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "migrations/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "c8": {
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/tests/**"
    ],
    "reporter": [
      "text",
      "lcov",
      "html"
    ],
    "all": false,
    "check-coverage": true,
    "lines": 60,
    "functions": 60,
    "branches": 60,
    "statements": 60
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "build:app": "tsc",
    "start": "node dist/main.js",
    "test": "node --test dist/tests/integration.test.js",
    "coverage": "c8 node --test dist/tests/integration.test.js",
    "test:run": "tsc && node --test dist/tests/integration.test.js",
    "test:system": "tsc && node dist/tests/system/runner.js",
    "test:security": "tsc && node --test dist/tests/system/security.test.js",
    "test:memory": "tsc && node --test dist/tests/system/memory-safety.test.js",
    "test:load": "tsc && node --test dist/tests/system/load-testing.test.js",
    "test:fuzz": "tsc && node --test dist/tests/system/fuzz-testing.test.js",
    "test:chaos": "tsc && node --test dist/tests/system/chaos-testing.test.js",
    "test:infra": "tsc && node --test dist/tests/system/infrastructure.test.js",
    "test:system:ci": "tsc && node dist/tests/system/runner.js --ci --json --skip-pg",
    "migrate": "node dist/main.js migrate",
    "dev": "tsc && node dist/main.js",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build && npm run lint",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "keywords": [
    "typescript",
    "framework",
    "backend",
    "http",
    "server",
    "postgresql",
    "wire-protocol",
    "dependency-injection",
    "ioc",
    "websocket",
    "sse",
    "streaming",
    "memory-safe",
    "clustering",
    "jwt",
    "aes-gcm",
    "rate-limiting",
    "esm",
    "nodejs",
    "rest-api",
    "microservices",
    "real-time",
    "security",
    "openapi",
    "scram-sha-256",
    "no-express",
    "production-grade"
  ],
  "author": "street contributors",
  "license": "MIT",
  "homepage": "https://hassanmubiru.github.io/street/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hassanmubiru/street.git"
  },
  "bugs": {
    "url": "https://github.com/hassanmubiru/street/issues"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.5.10",
    "c8": "^11.0.0",
    "js-yaml": "^4.1.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
