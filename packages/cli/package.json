{
  "name": "@streetjs/cli",
  "version": "1.0.0",
  "description": "Street framework CLI — scaffolding, dev server, code generation, and migration management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "street": "./bin/street.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "bin/street.js",
    "templates/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/tests/*.test.js",
    "coverage": "c8 node --test dist/tests/*.test.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@streetjs/core": "^1.0.3"
  },
  "c8": {
    "include": ["src/**/*.ts"],
    "exclude": ["src/tests/**"],
    "reporter": ["text", "lcov", "html"],
    "all": true
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "c8": "^11.0.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "street",
    "framework",
    "cli",
    "scaffolding",
    "typescript",
    "code-generation"
  ],
  "author": "street contributors",
  "license": "MIT",
  "homepage": "https://hassanmubiru.github.io/street",
  "repository": {
    "type": "git",
    "url": "https://github.com/hassanmubiru/street.git"
  },
  "bugs": {
    "url": "https://github.com/hassanmubiru/street/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
