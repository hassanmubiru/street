{
  "name": "@streetjs/plugin-s3",
  "version": "1.0.3",
  "description": "Official Street Framework plugin: AWS S3 object storage. Signed manifest, PluginModule SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./manifest": "./manifest.json",
    "./manifest.signed": "./manifest.signed.json"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "manifest.json",
    "manifest.signed.json",
    "README.md",
    "example/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "sign": "node scripts/sign-manifest.mjs",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build && npm run sign"
  },
  "dependencies": {
    "streetjs": "^1.0.6"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "street",
    "streetjs",
    "street-plugin",
    "s3",
    "aws",
    "object-storage",
    "storage"
  ],
  "author": "street contributors",
  "license": "MIT",
  "homepage": "https://hassanmubiru.github.io/StreetJS/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hassanmubiru/StreetJS.git"
  },
  "bugs": {
    "url": "https://github.com/hassanmubiru/StreetJS/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
