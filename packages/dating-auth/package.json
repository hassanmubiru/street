{
  "name": "@streetjs/dating-auth",
  "version": "1.0.0",
  "description": "Consumer-platform reference package: dating authentication built entirely on Street core JwtService, SessionManager, and AbuseEngine — no independent auth logic.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "tsc && node --test dist/tests/dating-auth.test.js",
    "example": "tsc && node examples/index.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "street",
    "streetjs",
    "street-framework",
    "dating",
    "auth",
    "authentication",
    "jwt",
    "session",
    "abuse-prevention"
  ],
  "author": "street contributors",
  "license": "MIT",
  "homepage": "https://hassanmubiru.github.io/street/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hassanmubiru/street.git"
  },
  "bugs": {
    "url": "https://github.com/hassanmubiru/street/issues"
  },
  "dependencies": {
    "streetjs": "^1.0.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
