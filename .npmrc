# Framework integration packages (@streetjs/react, next, vue, nuxt, *-ui) declare
# React/Vue/Next as PEER dependencies — consumers provide them. During monorepo
# installs npm otherwise tries to auto-install mutually-incompatible peers
# (e.g. next@16 -> react-dom@19 vs react@18 devDep). Legacy peer resolution keeps
# the dev install deterministic; it has no effect on published package contents.
legacy-peer-deps=true
