{
  "uid": "street-plugin-host",
  "title": "Street Plugin Host",
  "schemaVersion": 39,
  "version": 1,
  "tags": [
    "street",
    "plugins",
    "plugin-host"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Plugins by state",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "plugin_host_plugins",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Signature failure rate",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(plugin_signature_failures_total[5m])",
          "legendFormat": "failures/s",
          "refId": "A"
        }
      ],
      "unit": "reqps"
    },
    {
      "id": 3,
      "title": "Install duration p95",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(plugin_install_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "unit": "s"
    }
  ]
}
