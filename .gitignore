# Ignore docs build and temporary files (but keep the doc sources tracked —
# the documentation certification suite requires docs/*.md to be in the repo).
docs/_site/
docs/.jekyll-cache/
docs/vendor/
docs/.bundle/

# Node modules
node_modules/

# Environment files (templates are explicitly re-included below)
.env
.env.*
!.env.example

# Credentials, private keys, and certificates — must never be committed
*.pem
*.key
*.p12
*.pfx
*.crt
*service-account*.json
*credentials*.json
aws-credentials.json

# Temp / cache scratch dirs
.tmp/
.cache/

# System test output
# System test results (from packages/core or anywhere)
**/system-test-results.json

# GitHub CLI scratch files
.gh_*

# Jekyll build logs
.jekyll_build_output*

# NPM publish/view logs
.npm_*

# Coverage output
coverage/

# Build output — rebuilt by CI, not source-controlled
dist/
packages/*/dist/

# Generated certification / benchmark artifacts
certification-report.json
RELEASE-CERTIFICATION.md
benchmark-report.json
benchmark-report.md
benchmark-history.json
ratelimit-benchmark.json

# Verification Artifacts — produced by executed commands, uploaded from CI,
# never hand-authored or source-controlled (samples may be added explicitly).
verification-artifacts/

# Isolated comparative-benchmark env (deps only; results.* are committed evidence)
benchmarks/compare/node_modules/
benchmarks/compare/package-lock.json

# General log files
log.txt
*.log
*.tgz
*.street.md
# local CI tooling (kind/kubectl binaries) — never commit
.tooling/

# SQLite WASM runtime binary — not committed (Scorecard Binary-Artifacts).
# Downloaded + SHA-256-verified at build time by
# packages/core/src/database/sqlite/download-wasm.mjs (run via the core
# package's prebuild/build:app scripts). The built dist/ tarball still bundles
# it, so published consumers are unaffected.
packages/core/src/database/sqlite/sqlite3.wasm

*.street-signing.pub.pem
*.street-signing.pem
*.CLAUDE.md
CLAUDE.md
artifacts/

.scaffold-test/

# CLI scaffold scratch dirs used by local manual testing (never committed)
packages/cli/.e2e/
packages/cli/.fin/
packages/cli/.t/
packages/cli/.tmp-scaffold/
packages/cli/.itest/
packages/cli/.itest-*/

# Kiro spec working files — kept local, not source-controlled
.kiro/specs/

# Local-only website enterprise audit (not source-controlled)
STREET_WEBSITE_ENTERPRISE_AUDIT.md

# Generated build/release artifacts (produced in CI, attached to releases)
sbom.json
release-inputs.json

# ── Repository classification: RESTRICTED patterns (SECURITY-CLASSIFICATION.md) ──
# IaC state & secrets
*.tfstate
*.tfstate.*
*.tfvars
.terraform/
# Cluster / cloud credentials
kubeconfig
*.kubeconfig
*service-account*.json
*credentials*.json
aws-credentials.json
gcp-*.json
# Java keystores
*.jks
*.keystore
# npm auth (only the redacted .npmrc without _authToken should be tracked)
.npmrc.local
